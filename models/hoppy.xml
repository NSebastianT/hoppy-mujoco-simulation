<mujoco model="hoppy">
    <!-- ================================================================
         HOPPY physics model (simplified capsule dynamics + tuned hybrid
         controller). Parameters follow the project rubric / technical guide.

         Phase 1 - Mechanical model:
           * 4 DoF: gantry yaw (passive) + pitch (passive), hip + knee (active).
             NOTE: passive yaw is added in a later step (see TODO below).
           * armature  = N^2 * I_r   (reflected rotor inertia, guide eq. 6/8)
           * damping   ~ (k_v*k_T/R_w)*N^2 + reducer losses (back-EMF, eq. 9)
           * knee parallel spring via stiffness/springref (energy storage)
         Motor gear ratios: N_H = 26.9, N_K = 28.8.
         Assumed rotor inertia I_r = 2.5e-5 kg*m^2 (REPLACE with datasheet).
         ================================================================ -->
    <compiler angle="radian" coordinate="local"/>

    <!-- Rubric 3.1 recommended solver/contact configuration -->
    <option gravity="0 0 -9.81"
            timestep="0.001"
            integrator="RK4"
            solver="Newton"
            iterations="50"
            tolerance="1e-8"/>

    <default>
        <joint damping="0.02" armature="0.0"/>
        <geom friction="1.5 0.02 0.001"
              solref="0.01 1"
              solimp="0.95 0.99 0.001"/>
    </default>

    <worldbody>
        <light pos="0 -3 3" dir="0 1 -1"/>
        <camera name="main_camera" pos="0 -1.6 0.55" xyaxes="1 0 0 0 0 1"/>

        <geom name="floor" type="plane" size="2 2 0.1" rgba="0.8 0.8 0.8 1"/>

        <body name="gantry_yaw_body" pos="0 0 0.48">
            <geom name="yaw_hub" type="sphere" size="0.035" mass="0.05" rgba="0.1 0.1 0.1 1"/>

            <body name="gantry_pitch_body" pos="0 0 0">
                <!-- Passive pitch joint (theta2): no actuator -->
                <joint name="gantry_pitch" type="hinge" axis="0 1 0"
                       limited="true" range="-0.15 0.30"
                       damping="0.12" armature="0.002"/>

                <geom name="gantry_bar" type="capsule"
                      fromto="-0.35 0 0 0.70 0 0"
                      size="0.018" mass="0.12" rgba="0.1 0.1 0.1 1"/>

                <!-- Counterweight at the opposite end of the gantry -->
                <geom name="counterweight" type="sphere" pos="-0.35 0 0"
                      size="0.07" mass="0.35" rgba="0.2 0.2 0.8 1"/>

                <body name="hip_body" pos="0.70 0 0">
                    <!-- Active hip joint (theta3). armature = N_H^2 * I_r = 26.9^2 * 2.5e-5 -->
                    <joint name="hip" type="hinge" axis="1 0 0"
                           limited="true" range="-1.8 1.8"
                           damping="0.08" armature="0.0181"/>

                    <geom name="hip_motor_mass" type="box" pos="0 0 0"
                          size="0.06 0.06 0.06" mass="0.18"
                          rgba="0.05 0.05 0.05 1"/>

                    <geom name="upper_leg" type="capsule"
                          fromto="0 0 0 0 0 -0.22"
                          size="0.025" mass="0.08"
                          rgba="0.8 0.2 0.2 1"/>

                    <body name="lower_leg_body" pos="0 0 -0.22">
                        <!-- Active knee joint (theta4). armature = N_K^2 * I_r = 28.8^2 * 2.5e-5.
                             Parallel spring (stiffness/springref) stores/releases hop energy. -->
                        <joint name="knee" type="hinge" axis="1 0 0"
                               limited="true" range="-2.4 0.2"
                               damping="0.08" armature="0.0207"
                               stiffness="2.0" springref="-0.7"/>

                        <geom name="lower_leg" type="capsule"
                              fromto="0 0 0 0 0 -0.22"
                              size="0.025" mass="0.08"
                              rgba="0.2 0.7 0.2 1"/>

                        <body name="foot_body" pos="0 0 -0.22">
                            <geom name="foot" type="sphere" size="0.035" mass="0.05"
                                  rgba="0.02 0.02 0.02 1"/>
                            <site name="foot_site" pos="0 0 0" size="0.01" rgba="1 0 0 1"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="hip_motor" joint="hip" gear="1" ctrllimited="true" ctrlrange="-35 35"/>
        <motor name="knee_motor" joint="knee" gear="1" ctrllimited="true" ctrlrange="-35 35"/>
    </actuator>

    <keyframe>
        <!-- Natural standing pose with the foot resting on the floor -->
        <key name="home" qpos="0 0.025 -0.10"/>
    </keyframe>
</mujoco>
