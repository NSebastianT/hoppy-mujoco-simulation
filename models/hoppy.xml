<mujoco model="hoppy">
    <compiler angle="radian" coordinate="local" meshdir="../assets/meshes/hoppy_official"/>

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <asset>
        <mesh name="official_link1_mesh" file="link1_visual.stl" scale="0.001 0.001 0.001"/>
        <mesh name="official_link2_mesh" file="link2_visual.stl" scale="0.001 0.001 0.001"/>
        <mesh name="official_link3_mesh" file="link3_visual.stl" scale="0.001 0.001 0.001"/>
        <mesh name="official_link4_mesh" file="link4_visual.stl" scale="0.001 0.001 0.001"/>
    </asset>

    <default>
        <joint damping="0.02" armature="0.0"/>
        <geom friction="1.5 0.02 0.001"
              solref="0.01 1"
              solimp="0.95 0.99 0.001"/>
    </default>

    <worldbody>
        <light pos="0 -3 3" dir="0 1 -1"/>
        <camera name="main_camera" pos="0 -1.6 0.55" xyaxes="1 0 0 0 0 1"/>

        <geom name="floor" type="plane" size="2 2 0.1" rgba="0.8 0.8 0.8 1"/>

        <body name="official_hoppy_reference" pos="-0.60 0 0.05">
            <geom name="reference_link1_visual" type="mesh" mesh="official_link1_mesh"
                  rgba="0.8 0.1 0.1 0.25" contype="0" conaffinity="0"/>
            <geom name="reference_link2_visual" type="mesh" mesh="official_link2_mesh"
                  rgba="0.1 0.1 0.8 0.25" contype="0" conaffinity="0"/>
            <geom name="reference_link3_visual" type="mesh" mesh="official_link3_mesh"
                  rgba="0.9 0.8 0.1 0.25" contype="0" conaffinity="0"/>
            <geom name="reference_link4_visual" type="mesh" mesh="official_link4_mesh"
                  rgba="0.1 0.7 0.1 0.25" contype="0" conaffinity="0"/>
        </body>

        <body name="gantry_yaw_body" pos="0 0 0.48">
            <geom name="yaw_hub" type="sphere" size="0.035" mass="0.05" rgba="0.1 0.1 0.1 1"/>

            <body name="gantry_pitch_body" pos="0 0 0">
                <joint name="gantry_pitch" type="hinge" axis="0 1 0"
                       limited="true" range="-0.15 0.30"
                       damping="0.12" armature="0.002"/>

                <geom name="official_gantry_visual" type="mesh" mesh="official_link2_mesh"
                      pos="0 0 0"
                      quat="0.7071068 0 0.7071068 0"
                      rgba="0.55 0.55 0.55 0.85"
                      contype="0" conaffinity="0" density="0"/>

                <geom name="gantry_bar" type="capsule"
                      fromto="-0.35 0 0 0.70 0 0"
                      size="0.018" mass="0.12" rgba="0.05 0.05 0.05 0.18"/>

                <geom name="counterweight" type="sphere" pos="-0.35 0 0"
                      size="0.07" mass="0.35" rgba="0.1 0.1 0.9 0.18"/>

                <body name="hip_body" pos="0.70 0 0">
                    <joint name="hip" type="hinge" axis="1 0 0"
                           limited="true" range="-1.8 1.8"
                           damping="0.08" armature="0.001"/>

                    <geom name="hip_motor_mass" type="box" pos="0 0 0"
                          size="0.06 0.06 0.06" mass="0.18"
                          rgba="0.05 0.05 0.05 1"/>

                    <geom name="official_upper_leg_visual" type="mesh" mesh="official_link3_mesh"
                          pos="0 0 -0.11"
                          rgba="0.9 0.8 0.1 0.90"
                          contype="0" conaffinity="0" density="0"/>

                    <geom name="upper_leg" type="capsule"
                          fromto="0 0 0 0 0 -0.22"
                          size="0.025" mass="0.08"
                          rgba="0.8 0.1 0.1 0.18"/>

                    <body name="lower_leg_body" pos="0 0 -0.22">
                        <joint name="knee" type="hinge" axis="1 0 0"
                               limited="true" range="-2.4 0.2"
                               damping="0.08" armature="0.001"/>

                        <geom name="official_lower_leg_visual" type="mesh" mesh="official_link4_mesh"
                              pos="0 0 -0.055"
                              rgba="0.1 0.7 0.1 0.90"
                              contype="0" conaffinity="0" density="0"/>

                        <geom name="lower_leg" type="capsule"
                              fromto="0 0 0 0 0 -0.22"
                              size="0.025" mass="0.08"
                              rgba="0.1 0.8 0.1 0.18"/>

                        <body name="foot_body" pos="0 0 -0.22">
                            <geom name="foot" type="sphere" size="0.035" mass="0.05"
                                  rgba="0.02 0.02 0.02 1"/>
                            <site name="foot_site" pos="0 0 0" size="0.01" rgba="1 0 0 1"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="hip_motor" joint="hip" gear="1" ctrllimited="true" ctrlrange="-35 35"/>
        <motor name="knee_motor" joint="knee" gear="1" ctrllimited="true" ctrlrange="-35 35"/>
    </actuator>
</mujoco>