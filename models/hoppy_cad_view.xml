<mujoco model="hoppy_cad_view">
    <!-- Faithful CAD visualization built from the official HOPPY-E0-final URDF.
         Visual-only (no collisions, not the physics model). The kinematics and
         body transforms come straight from the SolidWorks->URDF export; meshes
         are the official ones, decimated by tools/prepare_cad_view_meshes.py. -->
    <compiler angle="radian" meshdir="../assets/meshes/hoppy_official_urdf"/>
    <option gravity="0 0 -9.81"/>

    <asset>
        <mesh name="base_link" file="base_link.STL"/>
        <mesh name="Link1" file="Link1.STL"/>
        <mesh name="Link2" file="Link2.STL"/>
        <mesh name="Link3" file="Link3.STL"/>
        <mesh name="Link4" file="Link4.STL"/>
    </asset>

    <default>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0"/>
    </default>

    <worldbody>
        <light pos="0.4 -1.5 2.5" dir="-0.2 1 -1.6"/>
        <camera name="main_camera" pos="-0.35 -1.7 0.55" xyaxes="1 0 0 0 0.35 1"/>

        <geom name="floor" type="plane" size="2 2 0.1" rgba="0.8 0.8 0.8 1"/>

        <body name="base_link">
            <inertial pos="0 0 0.0166702" quat="0.5 0.5 -0.5 0.5" mass="0.384125"
                      diaginertia="0.0011789 0.000672971 0.000672971"/>
            <geom mesh="base_link" rgba="0.55 0.55 0.57 1"/>

            <body name="Link1" pos="0 0 0.04">
                <inertial pos="1.19035e-06 -7.23296e-08 0.110977"
                          quat="0.999539 -3.72317e-07 -1.22626e-05 -0.0303481"
                          mass="1.05189" diaginertia="0.0015755 0.00119525 0.000930447"/>
                <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-3.14 3.14"/>
                <geom mesh="Link1" rgba="0.30 0.42 0.80 1"/>

                <body name="Link2" pos="-0.00227444 -0.037431 0.21"
                      quat="0.705252 0.707058 0.00831865 -0.0511876">
                    <inertial pos="-0.513966 0.0016327 -0.00902703"
                              quat="0.500001 0.500001 0.499999 0.499999"
                              mass="1.87654" diaginertia="0.0636508 0.0630427 0.00259304"/>
                    <joint name="joint2" pos="0 0 0" axis="0 0 1" range="-0.5 0.5"/>
                    <geom mesh="Link2" rgba="0.62 0.62 0.64 1"/>
                    <geom name="cw_clamp" type="box" pos="0.34 0 -0.038" size="0.022 0.03 0.05" rgba="0.50 0.50 0.55 1"/>
                    <geom name="cw_1" type="capsule" fromto="0.27 0 0.007 0.41 0 0.007" size="0.028" rgba="0.13 0.13 0.15 1"/>
                    <geom name="cw_2" type="capsule" fromto="0.27 0 -0.083 0.41 0 -0.083" size="0.028" rgba="0.13 0.13 0.15 1"/>

                    <body name="Link3" pos="-0.6585 0 0.0425"
                          quat="0.677009 -0.204104 -0.677009 0.204104">
                        <inertial pos="0.00864428 -0.0327981 0.0561207"
                                  quat="0.511267 0.498647 -0.497438 0.492456"
                                  mass="0.332207" diaginertia="0.000345397 0.000299821 7.12146e-05"/>
                        <joint name="joint3" pos="0 0 0" axis="0 0 1" range="-0.5 0.9"/>
                        <geom mesh="Link3" rgba="0.90 0.80 0.12 1"/>

                        <body name="Link4" pos="0 -0.1 0.0095"
                              quat="0 -0.288647 -0.957436 0">
                            <inertial pos="-0.0162703 -0.0747425 -0.0260399"
                                      quat="0.285014 0.647037 -0.285746 0.646884"
                                      mass="0.172793" diaginertia="0.000170791 0.000165707 3.2109e-05"/>
                            <joint name="joint4" pos="0 0 0" axis="0 0 -1" range="-1.3 0.4"/>
                            <geom mesh="Link4" rgba="0.20 0.70 0.25 1"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <keyframe>
        <!-- Slight boom pitch (~3 deg) so the foot rests on the floor for display -->
        <key name="stand" qpos="0 0.06 0 0"/>
    </keyframe>
</mujoco>
